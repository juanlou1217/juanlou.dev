# ============================================
# 数据库配置 (必需)
# ============================================
# 用途：存储博客文章的浏览量、点赞数等统计数据
# 格式：postgresql://用户名:密码@主机地址:端口/数据库名
# 示例：postgresql://myuser:mypassword@localhost:5432/myblog
POSTGRES_URL=


# ============================================
# Giscus 评论系统配置 (可选 - 推荐)
# ============================================
# 用途：为博客文章添加评论功能，基于 GitHub Discussions
# 获取方式：访问 https://giscus.app/zh-CN 并按照提示配置
# 
# 你的 GitHub 仓库（格式：用户名/仓库名）
NEXT_PUBLIC_GISCUS_REPO=
# 仓库 ID（由 Giscus 自动生成）
NEXT_PUBLIC_GISCUS_REPOSITORY_ID=
# Discussion 分类名称（例如：Announcements）
NEXT_PUBLIC_GISCUS_CATEGORY=
# Discussion 分类 ID（由 Giscus 自动生成）
NEXT_PUBLIC_GISCUS_CATEGORY_ID=


# ============================================
# 其他评论系统配置 (可选 - 不推荐)
# ============================================
# 注意：以下配置项目前未使用，可以忽略
UTTERANCES_REPO=
DISQUS_SHORTNAME=
NEXT_PUBLIC_CREATE_DISCUS_ON_TWITTER=
NEXT_PUBLIC_CREATE_DISCUS_ON_GITHUB=
NEXT_PUBLIC_SHARE_ON_FACEBOOK=
NEXT_PUBLIC_SHARE_ON_TWITTER=


# ============================================
# GitHub API 配置 (可选)
# ============================================
# 用途：在"项目"页面展示你的 GitHub 仓库信息（星标数、Fork 数等）
# 获取方式：访问 https://github.com/settings/tokens 创建 Personal Access Token
# 权限要求：只需勾选 "public_repo"
GITHUB_API_TOKEN=
